<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@estilos.css" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.puntomaya.controller.MenuController"
            prefWidth="700" prefHeight="480">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 16;">
            <Label text="PuntoMaya" styleClass="titulo"/>
            <Label fx:id="lblBienvenida" styleClass="subtitulo"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20">
            <Button fx:id="btnVentas" text="Vender" prefWidth="220" onAction="#abrirVentas"/>
            <Button fx:id="btnClientes" text="Clientes / Fiados" prefWidth="220" onAction="#abrirClientes"/>
            <Button fx:id="btnProductos" text="Productos y precios" prefWidth="220"
                    styleClass="button-secundario" onAction="#abrirProductos"/>
            <Button fx:id="btnInventario" text="Inventario" prefWidth="220"
                    styleClass="button-secundario" onAction="#abrirInventario"/>
            <Button fx:id="btnReportes" text="Reportes" prefWidth="220"
                    styleClass="button-secundario" onAction="#abrirReportes"/>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 16;">
            <Button text="Cerrar sesión" styleClass="button-peligro" onAction="#cerrarSesion"/>
        </HBox>
    </bottom>

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>
</BorderPane>
